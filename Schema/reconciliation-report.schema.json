{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "reconciliation-report.schema.json",
  "title": "ReconciliationReport",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "matched": {
      "type": "array",
      "items": {
        "$ref": "reconciliation-pair.schema.json"
      }
    },
    "amount_mismatch": {
      "type": "array",
      "items": {
        "$ref": "reconciliation-pair.schema.json"
      }
    },
    "date_mismatch": {
      "type": "array",
      "items": {
        "$ref": "reconciliation-pair.schema.json"
      }
    },
    "suspicious": {
      "type": "array",
      "items": {
        "$ref": "reconciliation-pair.schema.json"
      }
    },
    "unmatched_source": {
      "type": "array",
      "items": {
        "$ref": "reconciliation-record.schema.json"
      }
    },
    "unmatched_reference": {
      "type": "array",
      "items": {
        "$ref": "reconciliation-record.schema.json"
      }
    },
    "set_summary": {
      "$ref": "reconciliation-set-summary.schema.json"
    },
    "source_total": {
      "type": "number"
    },
    "reference_total": {
      "type": "number"
    },
    "net_difference": {
      "type": "number"
    },
    "match_rate": {
      "type": "number"
    },
    "source_count": {
      "type": "integer",
      "minimum": 0
    },
    "reference_count": {
      "type": "integer",
      "minimum": 0
    }
  },
  "required": [
    "matched",
    "amount_mismatch",
    "date_mismatch",
    "suspicious",
    "unmatched_source",
    "unmatched_reference",
    "set_summary",
    "source_total",
    "reference_total",
    "net_difference",
    "match_rate",
    "source_count",
    "reference_count"
  ]
}
