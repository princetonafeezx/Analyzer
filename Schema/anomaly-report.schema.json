{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "anomaly-report.schema.json",
  "title": "AnomalyReport",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "anomalies": {
      "type": "array",
      "items": {
        "$ref": "spending-anomaly-row.schema.json"
      }
    },
    "counts": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "affected_categories": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    }
  },
  "required": [
    "anomalies",
    "counts",
    "affected_categories"
  ]
}
