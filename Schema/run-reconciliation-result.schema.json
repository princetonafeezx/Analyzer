{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "run-reconciliation-result.schema.json",
  "title": "RunReconciliationResult",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "report": {
      "$ref": "reconciliation-report.schema.json"
    },
    "report_text": {
      "type": "string"
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "duplicate_source": {
      "$ref": "duplicate-detection-result.schema.json"
    },
    "duplicate_reference": {
      "$ref": "duplicate-detection-result.schema.json"
    },
    "output_path": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "required": [
    "report",
    "report_text",
    "warnings",
    "duplicate_source",
    "duplicate_reference",
    "output_path"
  ]
}
