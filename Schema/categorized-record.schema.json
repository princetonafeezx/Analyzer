{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "categorized-record.schema.json",
  "title": "CategorizedRecord",
  "description": "Single transaction row after classification or when loaded for analysis.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "date": {
      "anyOf": [
        {
          "type": "string",
          "format": "date"
        },
        {
          "type": "string"
        }
      ],
      "description": "Transaction date. Prefer ISO 8601 format such as 2026-04-10."
    },
    "merchant": {
      "type": "string"
    },
    "amount": {
      "type": "number"
    },
    "category": {
      "type": "string"
    },
    "subcategory": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0
    },
    "match_type": {
      "type": "string"
    }
  },
  "required": [
    "date",
    "merchant",
    "amount",
    "category"
  ]
}
